{
  "name": "extension-a11y-checker-storage",
  "version": "0.1.0",
  "author": {
    "name": "Lukas Fritze",
    "email": "l.fritze@mittwald.de"
  },
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "yarn start",
    "build": "yarn compile",
    "start": "yarn compile && MONGODB_URI=mongodb://localhost:27017/extension-a11y-checker node dist/test.js",
    "lint": "exit 1",
    "compile": "tsc",
    "format": "prettier $@ '**/*.{ts,tsx,yaml,yml,json,md,mdx}' --write"
  },
  "dependencies": {
    "@typegoose/typegoose": "^12.10.1",
    "mongodb": "^6.12.0",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "eslint": "^9",
    "typescript": "^5"
  },
  "packageManager": "yarn@4.6.0"
}
