{
  "name": "extension-a11y-checker-executor",
  "version": "0.1.0",
  "author": {
    "name": "Lukas Fritze",
    "email": "l.fritze@mittwald.de"
  },
  "private": true,
  "type": "module",
  "scripts": {
    "build": "yarn compile",
    "start": "yarn compile && MONGODB_URI=mongodb://localhost:27017/extension-a11y-checker node --no-experimental-require-module dist/index.js",
    "compile": "tsc",
    "format": "prettier $@ '**/*.{ts,tsx,yaml,yml,json,md,mdx}' --write"
  },
  "dependencies": {
    "cron-parser": "^4.9.0",
    "extension-a11y-checker-storage": "workspace:*",
    "node-cron": "^3.0.3",
    "pa11y": "^8.0.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9",
    "eslint-config-next": "15.1.6",
    "typescript": "^5"
  },
  "packageManager": "yarn@4.6.0"
}
