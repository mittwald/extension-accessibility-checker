{
  "name": "extension-a11y-checker",
  "author": {
    "name": "Lukas Fritze",
    "email": "l.fritze@mittwald.de"
  },
  "packageManager": "yarn@4.6.0",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "nx run-many --target=lint",
    "lint:fix": "nx run-many --target=lint:fix",
    "format": "nx run-many --target=format",
    "format:check": "nx run-many --target=format:check",
    "dev": "yarn workspaces foreach --all --interlaced --parallel run dev",
    "build": "nx run-many --target=build",
    "start": "nx run-many --target=start",
    "compile": "yarn build"
  },
  "devDependencies": {
    "@nx/eslint": "^22.1.0",
    "@nx/vite": "^22.1.0",
    "@nx/web": "^22.1.0",
    "@vitest/ui": "^4.0.12",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "nx": "^22.1.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.12"
  }
}
